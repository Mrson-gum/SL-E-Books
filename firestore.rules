rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global architectural primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerifiedUser() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Entity shape blueprints (Anti-Update-Gap validations)
    function isValidBook(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.author is string && data.author.size() > 0 && data.author.size() <= 150
        && data.genre is string && data.genre.size() <= 50
        && data.coverType is string && (data.coverType == 'gradient' || data.coverType == 'image')
        && data.coverGradientIndex is int && data.coverGradientIndex >= 0 && data.coverGradientIndex <= 10
        && data.createdAt is string && data.createdAt.size() <= 40
        && (!data.keys().hasAny(['coverUrl']) || data.coverUrl is string && data.coverUrl.size() <= 2000)
        && (!data.keys().hasAny(['description']) || data.description is string && data.description.size() <= 5000)
        && (!data.keys().hasAny(['ownerId']) || data.ownerId is string && data.ownerId.size() <= 128)
        && (!data.keys().hasAny(['ownerEmail']) || data.ownerEmail is string && data.ownerEmail.size() <= 256)
        && (!data.keys().hasAny(['custom']) || data.custom is bool)
        && (!data.keys().hasAny(['parts']) || data.parts is list && data.parts.size() <= 80);
    }

    function isValidChapter(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 300
        && data.content is string && data.content.size() <= 100000
        && (!data.keys().hasAny(['order']) || data.order is int || data.order is float)
        && (!data.keys().hasAny(['partId']) || data.partId is string && data.partId.size() <= 128);
    }

    function isValidProgress(data) {
      return data.chapterId is string && data.chapterId.size() <= 128
        && data.updatedAt is string && data.updatedAt.size() <= 40;
    }

    function isValidUserProfile(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
        && data.bio is string && data.bio.size() <= 1000
        && (!data.keys().hasAny(['avatarIndex']) || data.avatarIndex is int)
        && (!data.keys().hasAny(['avatarUrl']) || data.avatarUrl is string && data.avatarUrl.size() <= 2000)
        && data.followersCount is int && data.followersCount >= 0
        && data.followingCount is int && data.followingCount >= 0
        && data.createdAt is string && data.createdAt.size() <= 40;
    }

    function isValidFollow(data) {
      return data.id is string && data.id.size() <= 256
        && data.followerId is string && data.followerId.size() <= 128
        && data.followedId is string && data.followedId.size() <= 128
        && data.createdAt is string && data.createdAt.size() <= 40;
    }

    function isValidMessage(data) {
      return data.id is string && data.id.size() <= 128
        && data.senderId is string && data.senderId.size() <= 128
        && data.senderEmail is string && data.senderEmail.size() <= 256
        && data.senderName is string && data.senderName.size() <= 100
        && data.receiverId is string && data.receiverId.size() <= 128
        && data.receiverName is string && data.receiverName.size() <= 100
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.content is string && data.content.size() > 0 && data.content.size() <= 5000
        && data.createdAt is string && data.createdAt.size() <= 40
        && data.isRead is bool;
    }

    function isValidLike(data) {
      return data.id is string && data.id.size() <= 256
        && data.userId is string && data.userId.size() <= 128
        && data.bookId is string && data.bookId.size() <= 128
        && data.createdAt is string && data.createdAt.size() <= 40;
    }

    function isValidRead(data) {
      return data.id is string && data.id.size() <= 256
        && data.userId is string && data.userId.size() <= 128
        && data.bookId is string && data.bookId.size() <= 128
        && data.createdAt is string && data.createdAt.size() <= 40;
    }

    // 4. Primary Books Match blocks
    match /books/{bookId} {
      allow read: if true;
      
      allow create: if isVerifiedUser() 
        && isValidId(bookId) 
        && isValidBook(incoming()) 
        && incoming().ownerId == request.auth.uid;
        
      allow update: if isVerifiedUser() 
        && isValidId(bookId) 
        && isValidBook(incoming()) 
        && existing().ownerId == request.auth.uid 
        && incoming().ownerId == existing().ownerId
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'author', 'genre', 'description', 'coverType', 'coverUrl', 'coverGradientIndex', 'custom', 'parts']);
        
      allow delete: if isVerifiedUser() 
        && isValidId(bookId)
        && existing().ownerId == request.auth.uid;
        
      // Master Gate: Chapters are synchronized safely via book ownership check
      match /chapters/{chapterId} {
        allow read: if true;
        
        allow create: if isVerifiedUser()
          && isValidId(chapterId)
          && isValidChapter(incoming())
          && get(/databases/$(database)/documents/books/$(bookId)).data.ownerId == request.auth.uid;
          
        allow update: if isVerifiedUser()
          && isValidId(chapterId)
          && isValidChapter(incoming())
          && get(/databases/$(database)/documents/books/$(bookId)).data.ownerId == request.auth.uid
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'order', 'partId']);
          
        allow delete: if isVerifiedUser()
          && isValidId(chapterId)
          && get(/databases/$(database)/documents/books/$(bookId)).data.ownerId == request.auth.uid;
      }
    }

    // 5. Reading progressions
    match /users/{userId}/progress/{bookId} {
      allow read, get, list: if isSignedIn() && request.auth.uid == userId;
      
      allow create, update: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(bookId)
        && isValidProgress(incoming())
        && exists(/databases/$(database)/documents/books/$(bookId));
        
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // 6. User Profiles (Public but write protected)
    match /profiles/{userId} {
      allow read: if true;
      
      allow create, update: if isSignedIn() 
        && request.auth.uid == userId
        && isValidId(userId)
        && isValidUserProfile(incoming());
    }

    // 7. Follow system
    match /follows/{followId} {
      allow read: if true;
      
      allow create: if isSignedIn() 
        && incoming().id == followId
        && incoming().followerId == request.auth.uid
        && isValidFollow(incoming());
        
      allow delete: if isSignedIn() 
        && existing().followerId == request.auth.uid;
    }

    // 8. Mailbox messaging
    match /messages/{messageId} {
      allow read, get, list: if isSignedIn() 
        && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      
      allow create: if isSignedIn() 
        && incoming().id == messageId
        && incoming().senderId == request.auth.uid
        && isValidMessage(incoming());
        
      allow update: if isSignedIn() 
        && existing().receiverId == request.auth.uid 
        && incoming().isRead == true 
        && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
        
      allow delete: if isSignedIn() 
        && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
    }

    // 9. Likes system
    match /likes/{likeId} {
      allow read: if true;
      
      allow create: if isSignedIn() 
        && incoming().id == likeId
        && incoming().userId == request.auth.uid
        && isValidLike(incoming());
        
      allow delete: if isSignedIn() 
        && existing().userId == request.auth.uid;
    }

    // 10. Reads system
    match /reads/{readId} {
      allow read: if true;
      
      allow create: if isSignedIn() 
        && incoming().id == readId
        && incoming().userId == request.auth.uid
        && isValidRead(incoming());
        
      allow delete: if isSignedIn() 
        && existing().userId == request.auth.uid;
    }
  }
}
